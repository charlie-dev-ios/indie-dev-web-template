# 開発サーバーのポート
# 複数の Next.js プロジェクトを並行起動する場合、このファイルを .env.local に
# コピーしてプロジェクトごとに重複しない値に変更すること。
# Bun が .env.local を自動的に環境変数として読み込み、`next dev` / `next start`
# / Playwright の webServer の listen port に反映される。
PORT=3000

# 例: 公開 API のベース URL
# NEXT_PUBLIC_API_URL=https://api.example.com

# Supabase（認証）
# Supabase ダッシュボードの Project Settings > API から取得する。
# どちらもブラウザに公開される値（anon key は RLS 前提の公開キー）。
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
